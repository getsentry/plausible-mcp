# Required: Plausible API key (Settings > API Keys)
PLAUSIBLE_API_KEY=your-api-key-here

# Optional: Self-hosted Plausible URL (defaults to https://plausible.io)
# PLAUSIBLE_BASE_URL=https://analytics.mycompany.com

# Optional: Default site domain (so you don't have to pass site_id every time)
# PLAUSIBLE_DEFAULT_SITE_ID=example.com

# Optional: For running LLM evals (bun run eval)
# ANTHROPIC_API_KEY=sk-ant-...
