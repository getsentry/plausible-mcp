{
  "name": "@frontic/plausible-mcp",
  "version": "0.2.0",
  "description": "MCP server for Plausible Analytics — query traffic, conversions, and compare periods from any AI tool",
  "type": "module",
  "bin": {
    "plausible-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "bun run tsc",
    "dev": "bun run src/index.ts",
    "start": "bun run dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval": "bun run evals/run.ts",
    "deploy": "SENTRY_RELEASE=$(node -p \"require('./package.json').version\") && npx wrangler deploy --var SENTRY_RELEASE:$SENTRY_RELEASE"
  },
  "keywords": [
    "mcp",
    "plausible",
    "analytics",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@sentry/cloudflare": "^10.45.0",
    "agents": "^0.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@sentry/cli": "^2",
    "@types/bun": "latest",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.91.0"
  }
}